// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  tier      String   @default("FREE") // "FREE" or "PREMIUM"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   Profile?
  resumes   Resume[]
  roadmaps  Roadmap[]
}

model Profile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetRole      String
  experienceLevel String
  readinessScore  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Resume {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileUrl         String?
  atsScore        Int      @default(0)
  missingKeywords String // Stored as comma-separated string for SQLite simplicity
  suggestions     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Roadmap {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  targetRole String
  phases     String // Stored as JSON string for SQLite simplicity
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
